{
  "expo": {
    "name": "medication-reminder",
    "slug": "medication-reminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#AED581"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.medicationreminder"
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.medicationreminder",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#AED581",
          "sounds": [
            "./assets/sounds/apoc_sound.mp3",
            "./assets/sounds/dozer_sound.mp3",
            "./assets/sounds/mouse_sound.mp3",
            "./assets/sounds/switch_sound.mp3",
            "./assets/sounds/tank_sound.mp3"
          ]
        }
      ],
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "ae3019d5-50da-46fa-9941-5085d4fb1b3d"
      }
    }
  }
}
